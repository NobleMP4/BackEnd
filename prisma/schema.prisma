generator client {
  provider     = "prisma-client"
  output       = "generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int                @id @default(autoincrement())
  firstName    String             @db.VarChar(100)
  lastName     String             @db.VarChar(100)
  email        String             @unique @db.VarChar(255)
  password     String             @db.VarChar(255)
  rank         Rank               @default(INSTRUCTEUR)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  participants EventParticipant[]

  @@map("users")
}

model Week {
  id               Int      @id @default(autoincrement())
  title            String
  discord_msg_id   String?
  created_at       DateTime @default(now())
  discord_msg_id_2 String?  @db.VarChar(255)
  events           Event[]
}

model Event {
  id           Int                @id @default(autoincrement())
  week_id      Int
  day_name     DayName
  title        String             @db.VarChar(255)
  event_time   String?            @db.VarChar(50)
  location     String?            @default("Mission Row") @db.VarChar(100)
  participants EventParticipant[]
  week         Week               @relation(fields: [week_id], references: [id], onDelete: Cascade)

  @@index([week_id], map: "events_week_id_fkey")
  @@map("events")
}

model EventParticipant {
  event_id Int
  user_id  Int
  event    Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user     User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([event_id, user_id])
  @@index([user_id], map: "event_participants_user_id_fkey")
  @@map("event_participants")
}

enum Rank {
  CS_IN_CHARGE
  COMMANDING_OFFICER
  ASSISTANT_COMMANDING_OFFICER
  INSTRUCTEUR_CONFIRMER
  INSTRUCTEUR
}

enum DayName {
  Lundi
  Mardi
  Mercredi
  Jeudi
  Vendredi
  Samedi
  Dimanche
}
