datasource db {
  provider = "mysql"
}

generator client {
  provider     = "prisma-client"
  output       = "generated/prisma"
  moduleFormat = "cjs"
}

// Grades officiels pour ton application
enum Rank {
  CS_IN_CHARGE
  COMMANDING_OFFICER
  ASSISTANT_COMMANDING_OFFICER
  INSTRUCTEUR_CONFIRMER
  INSTRUCTEUR
}

model User {
  id         Int      @id @default(autoincrement())
  firstName  String   @db.VarChar(100)
  lastName   String   @db.VarChar(100)
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255) // Sera hashé avec bcrypt
  rank       Rank     @default(INSTRUCTEUR)  
  // Relation avec les inscriptions aux événements
  participants EventParticipant[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

model Week {
  id                    Int      @id @default(autoincrement())
  title                 String
  discord_msg_id        String?  // Message serveur 1
  discord_msg_id_2      String?  // Message serveur 2
  created_at            DateTime @default(now())
  events                Event[]
}

model Event {
  id         Int      @id @default(autoincrement())
  week_id    Int
  week       Week     @relation(fields: [week_id], references: [id], onDelete: Cascade)
  
  day_name   DayName
  title      String   @db.VarChar(255)
  event_time String?  @db.VarChar(50)
  location   String?  @default("Mission Row") @db.VarChar(100)

  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  event_id Int
  user_id  Int
  event    Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user     User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([event_id, user_id])
  @@map("event_participants")
}

enum DayName {
  Lundi
  Mardi
  Mercredi
  Jeudi
  Vendredi
  Samedi
  Dimanche
}
